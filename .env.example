# Security Scanning App - Environment Variables

# Upload directory for scan artifacts (default: /tmp/security-scan-uploads)
# SCAN_UPLOAD_DIR=/tmp/security-scan-uploads

# Max upload size in MB (default: 100)
# SCAN_MAX_UPLOAD_SIZE_MB=100

# Infracost API key for Terraform cost scanning (optional)
# INFRACOST_API_KEY=your-key-here

# GitHub token for private repo cloning (optional)
# Create at https://github.com/settings/tokens - needs repo scope for private repos
# GITHUB_TOKEN=ghp_xxxx

# Or use prefixed env var:
# SCAN_INFRACOST_API_KEY=your-key-here

# Override scanner paths if not in PATH
# SCAN_TRIVY_PATH=/usr/local/bin/trivy
# SCAN_CHECKOV_PATH=/usr/local/bin/checkov
# SCAN_INFRACOST_PATH=/usr/local/bin/infracost
